# Server
PORT=3000
BASE_URL=https://tudominio.com
SESSION_SECRET=cambia_esto_por_una_cadena_aleatoria_larga

# Google OAuth
# Obtener en: https://console.cloud.google.com/ > APIs & Services > Credentials > Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tudominio.com/auth/google/callback

# Twilio (WhatsApp)
# Obtener en: https://console.twilio.com/ > Messaging > Try it out > Send a WhatsApp message
# WHATSAPP_NUMBER es el numero sin '+' ni espacios, ej: 14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_NUMBER=14155238886

# OpenRouter (compatible con OpenAI SDK)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Stripe
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Obtener en: https://dashboard.stripe.com/webhooks -> Add endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=
